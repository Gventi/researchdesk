{
  "$schema": "https://raw.githubusercontent.com/nicktomlin/tauri-schema/main/capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Research Desk",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "dialog:default",
    "dialog:allow-open",
    "shell:default"
  ]
}
